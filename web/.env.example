# Copy to `.env` in this folder for `next dev` / production (never commit `.env`).

# Comma-separated emails allowed for the admin dashboard (email step + Google callback).
# Matching is case-insensitive. Any address ending in @ednsy.com is also allowed without listing it here.
ADMIN_EMAILS=you@example.com, teammate@example.org

