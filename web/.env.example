NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for host/player server-side verification queries (player magic-link auth).
# Must belong to the same Supabase project as NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_SERVICE_ROLE_KEY=
PAYMENT_CODE_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Gmail inbox OAuth callback (must match Authorized redirect URIs in Google Cloud exactly).
# Local dev: http://localhost:3000/api/gmail/oauth/callback — not /api/admin/...
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/oauth/callback

# Google Maps Platform — optional for production. Only needed to run: pnpm download-facility-images (writes public/facilities/*.jpg). Not Gmail OAuth. If the key is ever exposed in chat or git, rotate it in GCP immediately.
GOOGLE_MAPS_API_KEY=

# Canonical base URL for this deployment (no trailing slash). Scheme optional for non-localhost hostnames (https assumed). Magic-link emails embed links under this origin → set to your production URL when deployed.
APP_ORIGIN=http://localhost:3000

# Comma-separated emails allowed to request an admin magic link and open /admin.
ADMIN_EMAILS=

# After running Supabase migrations: add rows to 6ixback.approved_hosts (Admin → Hosts tab, or SQL) so those emails can use /host/login.

# Magic link sign-in (hosts, players, and admins). Min 16 characters; generate a long random string.
MAGIC_AUTH_SECRET=

# Vercel Cron calls to /api/cron/* must send Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=
# Gmail reauthorization reminder lead time in days (default: 7).
GMAIL_REAUTH_REMINDER_LEAD_DAYS=7
# Optional: set true to accept sender email matching signup email during Gmail sync tests.
GMAIL_SYNC_TEST_MODE=false

# Transactional email via Resend (https://resend.com). Required to send magic links.
RESEND_API_KEY=
# Optional; defaults to "6IX BACK <noreply@6ixback.com>" if unset. Must be a domain you verified in Resend.
# RESEND_FROM_EMAIL="6IX BACK <play@yourdomain.com>"

# Troubleshooting (player login "Could not verify signups right now"):
# 1) Confirm NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are both set and from the same project.
# 2) Confirm DB has tables/columns used by player verification query: signups(player_email,status,game_id), games(id,status,starts_at).
# 3) Check server logs for [player-signups-by-email] and [request-player-magic-link] diagnostics.
